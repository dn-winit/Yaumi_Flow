# ============================================================
# Yaumi Flow -- Unified Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Database (YaumiLive -- source data) ---
DI_DB_HOST=your-db-server
DI_DB_PORT=1433
DI_DB_DATABASE=YaumiLive
DI_DB_USERNAME=your_username
DI_DB_PASSWORD=your_password
DI_DB_DRIVER={ODBC Driver 17 for SQL Server}

# --- LLM ---
LLM_PROVIDER=groq
LLM_API_KEY=your_api_key
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=45
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_HOURS=24
LLM_RATE_LIMIT_MAX_REQUESTS=10
LLM_RATE_LIMIT_WINDOW_SECONDS=60

# --- Service Ports ---
DI_PORT=8005
DF_PORT=8002
RO_PORT=8001
SS_PORT=8004
LLM_PORT=8003
WEBAPP_PORT=3000

# --- Frontend API URLs ---
VITE_DATA_IMPORT_URL=http://localhost:8005
VITE_FORECAST_URL=http://localhost:8002
VITE_RECOMMENDED_ORDER_URL=http://localhost:8001
VITE_SUPERVISION_URL=http://localhost:8004
VITE_ANALYTICS_URL=http://localhost:8003
