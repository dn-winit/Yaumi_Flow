FROM python:3.12-slim

# System deps for pyodbc (SQL Server driver)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gnupg2 unixodbc-dev gcc g++ && \
    curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft-prod.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/microsoft-prod.gpg] https://packages.microsoft.com/debian/12/prod bookworm main" > /etc/apt/sources.list.d/mssql-release.list && \
    apt-get update && ACCEPT_EULA=Y apt-get install -y msodbcsql17 && \
    apt-get purge -y gnupg2 gcc g++ && apt-get autoremove -y && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps (shared across all services)
COPY data_import/requirements.txt /tmp/req-di.txt
COPY demand_forecasting_pipeline/requirements.txt /tmp/req-df.txt
COPY recommended_order/requirements.txt /tmp/req-ro.txt
COPY sales_supervision/requirements.txt /tmp/req-ss.txt
COPY llm_analytics/requirements.txt /tmp/req-llm.txt

RUN pip install --no-cache-dir \
    -r /tmp/req-di.txt \
    -r /tmp/req-df.txt \
    -r /tmp/req-ro.txt \
    -r /tmp/req-ss.txt \
    -r /tmp/req-llm.txt

# Copy all modules + data
COPY data_import/ /app/data_import/
COPY demand_forecasting_pipeline/ /app/demand_forecasting_pipeline/
COPY recommended_order/ /app/recommended_order/
COPY sales_supervision/ /app/sales_supervision/
COPY llm_analytics/ /app/llm_analytics/
COPY data/ /app/data/

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
